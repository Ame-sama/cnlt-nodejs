<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Chỉnh sửa bài viết</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="form-container">
        <h1>Chỉnh sửa bài viết</h1>
        
        <form action="/posts/update/<%= post._id %>" method="POST">
            
            <div class="form-group">
                <label>Tiêu đề:</label>
                <input type="text" name="title" value="<%= post.title %>" required>
            </div>

            <div class="form-group">
                <label>Tác giả:</label>
                <input type="text" name="username" value="<%= post.username %>" required>
            </div>

            <div class="form-group">
                <label>Nội dung:</label>
                <textarea name="body" required><%= post.body %></textarea>
            </div>

            <button type="submit" class="btn-submit">Cập nhật bài viết</button>
        </form>

        <a href="/" class="back-link">← Hủy và quay về trang chủ</a>
    </div>
</body>
</html>