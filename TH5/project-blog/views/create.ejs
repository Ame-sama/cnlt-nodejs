<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Tạo bài viết mới</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="form-container">
        <h1>Tạo bài viết mới</h1>
        
        <form action="/posts/store" method="POST">
            
            <div class="form-group">
                <label>Tiêu đề:</label>
                <input type="text" name="title" placeholder="Nhập tiêu đề bài viết..." required>
            </div>

            <div class="form-group">
                <label>Tác giả</label>
                <input type="text" name="username" placeholder="Tên người đăng" required>
            </div>

            <div class="form-group">
                <label>Nội dung:</label>
                <textarea name="body" placeholder="Viết gì đó hay ho vào đây..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">Lưu bài viết</button>
        </form>

        <a href="/" class="back-link">← Về trang chủ</a>
    </div>
</body>
</html>